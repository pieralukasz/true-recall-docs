# Supabase Configuration
# Get these from your Supabase project settings
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# For server-side operations (webhooks, etc.)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Unkey (API key management + usage tracking)
# UNKEY_ROOT_KEY=unkey_xxx
# UNKEY_API_ID=api_xxx

# OpenRouter (AI model access — master key for proxy)
# OPENROUTER_API_KEY=sk-or-xxx

# Resend (Email notifications for waitlist)
# RESEND_API_KEY=re_xxx
# RESEND_SEGMENT_ID=your-segment-id
