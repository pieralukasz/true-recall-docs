---

---

<section id="newsletter" class="waitlist-section">
  <div class="waitlist-container">
    <h2 class="waitlist-title">Learn how to learn</h2>
    <p class="waitlist-subtitle">
      My personal newsletter about learning — spaced repetition, memory, and how
      we should actually study. Plus every True Recall release, straight to your
      inbox.
    </p>

    <form id="waitlist-form" class="waitlist-form">
      <div class="form-row">
        <label for="waitlist-email" class="sr-only">Email address</label>
        <input
          type="email"
          id="waitlist-email"
          name="email"
          required
          placeholder="you@example.com"
          class="form-input"
          autocomplete="email"
        />
        <button type="submit" id="waitlist-submit" class="waitlist-btn">
          <span id="btn-text">Subscribe</span>
          <span id="btn-loading" style="display:none">Subscribing...</span>
        </button>
      </div>
      <p class="legal-notice">No spam, unsubscribe anytime. See our <a href="/privacy">Privacy Policy</a>.</p>
    </form>

    <div id="waitlist-success" class="waitlist-success" style="display:none">
      <div class="waitlist-success-header">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polyline points="20 6 9 17 4 12"></polyline></svg
        >
        <p>You're in! Check your inbox for a confirmation.</p>
      </div>
      <div class="waitlist-success-cta">
        <p>
          One more thing — create a free True Recall account and you get free AI
          credits to generate flashcards. No credit card, no API key.
        </p>
        <a href="/login" class="btn waitlist-success-btn">Create Free Account</a>
      </div>
    </div>

    <div id="waitlist-error" class="waitlist-error" style="display:none"></div>
  </div>
</section>

<script>
  const form = document.getElementById("waitlist-form") as HTMLFormElement;
  const submitBtn = document.getElementById(
    "waitlist-submit",
  ) as HTMLButtonElement;
  const btnText = document.getElementById("btn-text")!;
  const btnLoading = document.getElementById("btn-loading")!;
  const successEl = document.getElementById("waitlist-success")!;
  const errorEl = document.getElementById("waitlist-error")!;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.style.display = "none";

    const email = (
      document.getElementById("waitlist-email") as HTMLInputElement
    ).value;

    submitBtn.disabled = true;
    btnText.style.display = "none";
    btnLoading.style.display = "inline";

    try {
      const res = await fetch("/api/waitlist", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });

      const data = await res.json();

      if (data.success) {
        form.style.display = "none";
        successEl.style.display = "block";
      } else {
        throw new Error(data.error || "Something went wrong");
      }
    } catch (err: unknown) {
      errorEl.textContent =
        err instanceof Error
          ? err.message
          : "Something went wrong. Please try again.";
      errorEl.style.display = "block";
      submitBtn.disabled = false;
      btnText.style.display = "inline";
      btnLoading.style.display = "none";
    }
  });
</script>

<style>
  .waitlist-section {
    margin: 1.5rem 0;
  }

  .waitlist-container {
    text-align: center;
    padding: 2.5rem 2rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: var(--tr-radius-md, 12px);
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--sl-color-accent) 8%, transparent),
      transparent
    );
  }

  .waitlist-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--sl-color-white);
    margin: 0 0 0.35rem;
    border: none;
    padding: 0;
  }

  .waitlist-subtitle {
    color: var(--sl-color-gray-2);
    font-size: 1.125rem;
    margin: 0 auto 1.5rem;
    max-width: 540px;
    line-height: 1.5;
  }

  .waitlist-form {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .form-row {
    display: flex;
    gap: 0.5rem;
    max-width: 480px;
    margin: 0 auto;
    width: 100%;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .form-input {
    flex: 1;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    color: var(--sl-color-white);
    font-size: 0.95rem;
    padding: 0.65rem 0.875rem;
    box-sizing: border-box;
    transition: border-color 0.15s;
    font-family: inherit;
    margin: 0 !important;
  }

  .form-input::placeholder {
    color: var(--sl-color-gray-3);
  }

  .form-input:focus {
    outline: none;
    border-color: var(--sl-color-accent);
    box-shadow: 0 0 0 3px
      color-mix(in srgb, var(--sl-color-accent) 20%, transparent);
  }

  .waitlist-btn {
    background: var(--sl-color-accent);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 0.65rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      background 0.15s,
      opacity 0.15s;
    font-family: inherit;
    white-space: nowrap;
  }

  .waitlist-btn:hover:not(:disabled) {
    background: var(--sl-color-accent-high);
  }

  .waitlist-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .waitlist-success {
    max-width: 540px;
    margin: 0 auto;
    text-align: left;
    color: var(--tr-color-success, #10b981);
    padding: 1rem 1.25rem;
    background: color-mix(
      in srgb,
      var(--tr-color-success, #10b981) 10%,
      transparent
    );
    border: 1px solid
      color-mix(in srgb, var(--tr-color-success, #10b981) 30%, transparent);
    border-radius: 8px;
  }

  .waitlist-success-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .waitlist-success-header svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .waitlist-success-header p {
    margin: 0;
    font-weight: 600;
  }

  .waitlist-success-cta {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid
      color-mix(in srgb, var(--tr-color-success, #10b981) 20%, transparent);
    text-align: center;
  }

  .waitlist-success-cta p {
    margin: 0 0 0.875rem;
    font-size: 0.9rem;
    color: var(--sl-color-gray-2);
  }

  .waitlist-success-btn {
    display: inline-block;
  }

  .waitlist-error {
    max-width: 480px;
    margin: 1rem auto 0;
    color: var(--tr-color-error, #ef4444);
    background: color-mix(
      in srgb,
      var(--tr-color-error, #ef4444) 10%,
      transparent
    );
    border: 1px solid
      color-mix(in srgb, var(--tr-color-error, #ef4444) 30%, transparent);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
  }

  .legal-notice {
    font-size: 0.8125rem;
    color: var(--sl-color-gray-3);
    margin-top: 0.75rem;
    text-align: center;
    line-height: 1.5;
  }

  .legal-notice a {
    color: var(--sl-color-accent-high);
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .form-row {
      flex-direction: column;
    }

    .waitlist-btn {
      width: 100%;
    }
  }
</style>
