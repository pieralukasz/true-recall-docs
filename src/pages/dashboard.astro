---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import { supabase } from "../lib/supabase";
import { POLAR_CUSTOMER_PORTAL_URL } from "../lib/constants";

// Auth check
const accessToken = Astro.cookies.get("sb-access-token")?.value;
const refreshToken = Astro.cookies.get("sb-refresh-token")?.value;

if (!accessToken) {
	return Astro.redirect("/login");
}

const { data: { user }, error: authError } = await supabase.auth.getUser(accessToken);

if (authError || !user) {
	// Try refresh
	if (refreshToken) {
		const { data: refreshData, error: refreshError } =
			await supabase.auth.refreshSession({ refresh_token: refreshToken });
		if (refreshError || !refreshData.session) {
			Astro.cookies.delete("sb-access-token", { path: "/" });
			Astro.cookies.delete("sb-refresh-token", { path: "/" });
			return Astro.redirect("/login");
		}
		Astro.cookies.set("sb-access-token", refreshData.session.access_token, {
			path: "/",
			httpOnly: true,
			secure: true,
			sameSite: "lax",
			maxAge: 60 * 60 * 24 * 7,
		});
		Astro.cookies.set("sb-refresh-token", refreshData.session.refresh_token, {
			path: "/",
			httpOnly: true,
			secure: true,
			sameSite: "lax",
			maxAge: 60 * 60 * 24 * 30,
		});
	} else {
		return Astro.redirect("/login");
	}
}

// Fetch subscription data
const { data: subscription } = await supabase
	.from("user_subscriptions")
	.select("*")
	.eq("user_id", user!.id)
	.single();

const tier = subscription?.tier ?? "none";
const apiKey = subscription?.litellm_api_key ?? null;
const budgetMax = tier === "starter" ? 3.5 : tier === "pro" ? 7.0 : tier === "free" ? 0.20 : 0;
const periodEnd = subscription?.current_period_end
	? new Date(subscription.current_period_end).toLocaleDateString("en-US", {
			month: "long",
			day: "numeric",
			year: "numeric",
		})
	: null;

// Handle logout
if (Astro.request.method === "POST") {
	const formData = await Astro.request.formData();
	if (formData.get("action") === "logout") {
		Astro.cookies.delete("sb-access-token", { path: "/" });
		Astro.cookies.delete("sb-refresh-token", { path: "/" });
		return Astro.redirect("/login");
	}
}
---

<BaseLayout title="Dashboard" description="Manage your True Recall subscription">
	<div class="dashboard">
		<div class="dashboard-header">
			<div>
				<h1>Dashboard</h1>
				<p>Welcome back, {user!.email}</p>
			</div>
			<form method="POST">
				<input type="hidden" name="action" value="logout" />
				<button type="submit" class="btn-logout">Sign Out</button>
			</form>
		</div>

		{apiKey ? (
			<div class="credits-card">
				<h2>{tier === "free" ? "Your Free Trial Key" : "Your Subscription Key"}</h2>
				<div class="key-display">
					<code id="api-key">{apiKey}</code>
					<button class="copy-btn" id="copy-btn" type="button">Copy</button>
				</div>
				<p class="key-hint">Paste this key in Obsidian → True Recall Settings → AI → Subscription Key</p>
				{tier === "free" && (
					<p class="key-hint" style="margin-top: 0.5rem; opacity: 0.9;">
						Free trial includes ~30 one-time AI generations.
						<a href="/pricing" style="color: inherit; text-decoration: underline;">Upgrade</a> for unlimited monthly access.
					</p>
				)}
			</div>
		) : (
			<div class="no-sub-card">
				<h2>No Active Subscription</h2>
				<p>Sign up for a plan to get a managed AI key with no setup required.</p>
				<a href="/pricing" class="btn">View Plans</a>
			</div>
		)}

		<div class="info-grid">
			<div class="info-card">
				<h3>Plan</h3>
				<div class="info-value">
					<span class:list={["tier-badge", `tier-${tier}`]}>
						{tier.charAt(0).toUpperCase() + tier.slice(1)}
					</span>
				</div>
			</div>

			<div class="info-card">
				<h3>Monthly Budget</h3>
				<div class="info-value">
					{budgetMax > 0 ? `$${budgetMax.toFixed(2)}` : "—"}
				</div>
			</div>

			<div class="info-card">
				<h3>Usage</h3>
				<div class="info-value">
					<div class="usage-bar-container" id="usage-container">
						{apiKey ? (
							<>
								<div class="usage-bar">
									<div class="usage-fill" id="usage-fill" style="width: 0%"></div>
								</div>
								<span class="usage-text" id="usage-text">Loading...</span>
							</>
						) : (
							<span class="usage-text">N/A</span>
						)}
					</div>
				</div>
			</div>

			<div class="info-card">
				<h3>Renews</h3>
				<div class="info-value">
					{periodEnd ?? "—"}
				</div>
			</div>
		</div>

		{tier === "free" ? (
			<div class="actions">
				<a href="/pricing" class="btn">
					Upgrade Plan
				</a>
			</div>
		) : tier !== "none" && (
			<div class="actions">
				<a href={POLAR_CUSTOMER_PORTAL_URL} class="btn" target="_blank" rel="noopener">
					Manage Subscription
				</a>
				<a href="/pricing" class="btn btn-secondary">
					Buy Token Top-up
				</a>
			</div>
		)}
	</div>
</BaseLayout>

<script define:vars={{ apiKey, tier }}>
	// Copy key to clipboard
	const copyBtn = document.getElementById("copy-btn");
	copyBtn?.addEventListener("click", async () => {
		if (!apiKey) return;
		await navigator.clipboard.writeText(apiKey);
		copyBtn.textContent = "Copied!";
		setTimeout(() => { copyBtn.textContent = "Copy"; }, 2000);
	});

	// Fetch live usage from status API
	if (apiKey) {
		fetch(`/api/subscription/status?key=${encodeURIComponent(apiKey)}`)
			.then((r) => r.json())
			.then((data) => {
				const fill = document.getElementById("usage-fill");
				const text = document.getElementById("usage-text");
				if (fill && text && data.budget_max > 0) {
					const pct = Math.min(100, (data.budget_spent / data.budget_max) * 100);
					fill.style.width = `${pct}%`;
					fill.classList.toggle("usage-high", pct > 80);
					const remaining = (data.budget_max - data.budget_spent).toFixed(2);
					text.textContent = `$${remaining} remaining of $${data.budget_max.toFixed(2)}`;
				}
			})
			.catch(() => {
				const text = document.getElementById("usage-text");
				if (text) text.textContent = "Could not load usage data";
			});
	}
</script>

<style>
	.dashboard {
		max-width: 800px;
		margin: 0 auto;
		padding-top: 1rem;
	}

	.dashboard-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 2rem;
	}

	.dashboard-header h1 {
		font-size: 2rem;
		margin-bottom: 0.25rem;
	}

	.dashboard-header p {
		color: var(--sl-color-gray-3);
	}

	.btn-logout {
		background: transparent;
		border: 1px solid var(--sl-color-gray-5);
		color: var(--sl-color-gray-3);
		padding: 0.5rem 1rem;
		border-radius: var(--tr-radius-sm);
		cursor: pointer;
		font-size: 0.875rem;
	}

	.btn-logout:hover {
		background: var(--sl-color-gray-6);
		color: var(--sl-color-white);
	}

	/* Subscription Key Card */
	.credits-card {
		background: linear-gradient(135deg, var(--sl-color-accent) 0%, var(--tr-color-accent-deep) 100%);
		border-radius: var(--tr-radius-md);
		padding: 2rem;
		margin-bottom: 2rem;
	}

	.credits-card h2 {
		font-size: 1rem;
		font-weight: 400;
		opacity: 0.9;
		margin-bottom: 1rem;
	}

	.key-display {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		background: rgba(0, 0, 0, 0.2);
		border-radius: var(--tr-radius-sm);
		padding: 0.75rem 1rem;
		margin-bottom: 0.75rem;
	}

	.key-display code {
		flex: 1;
		font-size: 0.9375rem;
		font-family: "SF Mono", "Fira Code", monospace;
		word-break: break-all;
		color: var(--sl-color-white);
	}

	.copy-btn {
		background: var(--tr-overlay-light);
		border: 1px solid var(--tr-overlay-light-hover);
		color: var(--sl-color-white);
		padding: 0.375rem 0.75rem;
		border-radius: var(--tr-radius-sm);
		cursor: pointer;
		font-size: 0.8125rem;
		white-space: nowrap;
	}

	.copy-btn:hover {
		background: var(--tr-overlay-light-hover);
	}

	.key-hint {
		font-size: 0.8125rem;
		opacity: 0.8;
	}

	/* No subscription card */
	.no-sub-card {
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-md);
		padding: 2rem;
		text-align: center;
		margin-bottom: 2rem;
	}

	.no-sub-card h2 {
		margin-bottom: 0.5rem;
	}

	.no-sub-card p {
		color: var(--sl-color-gray-3);
		margin-bottom: 1.5rem;
	}

	/* Info Grid */
	.info-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.info-card {
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-md);
		padding: 1.25rem;
	}

	.info-card h3 {
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--sl-color-gray-3);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.5rem;
	}

	.info-value {
		font-size: 1.25rem;
		font-weight: 600;
	}

	/* Tier badges */
	.tier-badge {
		display: inline-block;
		padding: 0.25rem 0.75rem;
		border-radius: var(--tr-radius-pill);
		font-size: 0.875rem;
		font-weight: 600;
	}

	.tier-free {
		background: var(--sl-color-gray-5);
		color: var(--sl-color-gray-2);
	}

	.tier-starter {
		background: color-mix(in srgb, var(--sl-color-accent) 20%, transparent);
		color: var(--sl-color-accent-high);
	}

	.tier-pro {
		background: color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
		color: var(--sl-color-accent-high);
	}

	/* Usage bar */
	.usage-bar-container {
		width: 100%;
	}

	.usage-bar {
		width: 100%;
		height: 8px;
		background: var(--sl-color-gray-5);
		border-radius: 4px;
		overflow: hidden;
		margin-bottom: 0.375rem;
	}

	.usage-fill {
		height: 100%;
		background: var(--sl-color-accent);
		border-radius: 4px;
		transition: width 0.5s ease;
	}

	.usage-fill.usage-high {
		background: var(--tr-color-error);
	}

	.usage-text {
		font-size: 0.8125rem;
		font-weight: 400;
		color: var(--sl-color-gray-3);
	}

	/* Actions */
	.actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		background: var(--sl-color-accent);
		color: var(--sl-color-white);
		border: none;
		border-radius: var(--tr-radius-sm);
		font-size: 1rem;
		font-weight: 500;
		cursor: pointer;
		transition: filter 0.2s;
		text-decoration: none;
	}

	.btn:hover {
		filter: brightness(1.1);
		text-decoration: none;
	}

	.btn-secondary {
		background: transparent;
		border: 1px solid var(--sl-color-gray-5);
	}

	.btn-secondary:hover {
		background: var(--sl-color-gray-6);
	}
</style>
