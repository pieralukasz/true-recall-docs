---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import { createSupabaseServerClient } from "../lib/supabase-server";

const supabase = createSupabaseServerClient(
	Astro.cookies,
	Astro.request.headers.get("cookie"),
);

let error = "";
let emailSent = false;

if (Astro.request.method === "POST") {
	const formData = await Astro.request.formData();
	const action = formData.get("action")?.toString();

	if (action === "magic-link") {
		const email = formData.get("email")?.toString().trim() ?? "";
		if (!email) {
			error = "Please enter your email address.";
		} else {
			const { error: otpError } = await supabase.auth.signInWithOtp({
				email,
				options: {
					emailRedirectTo: `${Astro.url.origin}/auth/confirm`,
				},
			});
			if (otpError) {
				error = otpError.message;
			} else {
				emailSent = true;
			}
		}
	} else if (action === "oauth-google" || action === "oauth-apple") {
		const provider = action === "oauth-google" ? "google" : "apple";
		const { data, error: oauthError } = await supabase.auth.signInWithOAuth({
			provider,
			options: {
				redirectTo: `${Astro.url.origin}/auth/callback`,
			},
		});
		if (oauthError || !data.url) {
			error = oauthError?.message ?? "Could not initiate sign-in. Please try again.";
		} else {
			return Astro.redirect(data.url);
		}
	}
}
---

<BaseLayout title="Sign In" description="Sign in to your True Recall account">
	<div class="auth-container">
		<h1>Sign in to True Recall</h1>
		<p class="subtitle">Manage your subscription and API key.</p>

		{error && <div class="error-message">{error}</div>}

		{emailSent ? (
			<div class="success-card">
				<div class="success-icon">✉</div>
				<h2>Check your email</h2>
				<p>We sent a magic link to your inbox. Click it to sign in — no password needed.</p>
				<p class="hint">Didn't receive it? Check your spam folder or <a href="/login">try again</a>.</p>
			</div>
		) : (
			<>
				<form method="POST" class="auth-form">
					<input type="hidden" name="action" value="magic-link" />
					<div class="form-group">
						<label for="email">Email</label>
						<input
							type="email"
							id="email"
							name="email"
							placeholder="you@example.com"
							required
							autocomplete="email"
						/>
					</div>
					<button type="submit" class="btn btn-full">Send Magic Link</button>
				</form>

				<div class="divider"><span>or continue with</span></div>

				<div class="oauth-buttons">
					<form method="POST">
						<input type="hidden" name="action" value="oauth-google" />
						<button type="submit" class="btn btn-oauth">
							<svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true" fill="none">
								<path d="M17.64 9.205c0-.639-.057-1.252-.164-1.841H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615Z" fill="#4285F4"/>
								<path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18Z" fill="#34A853"/>
								<path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332Z" fill="#FBBC05"/>
								<path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58Z" fill="#EA4335"/>
							</svg>
							Continue with Google
						</button>
					</form>

					<form method="POST">
						<input type="hidden" name="action" value="oauth-apple" />
						<button type="submit" class="btn btn-oauth">
							<svg width="18" height="18" viewBox="0 0 814 1000" aria-hidden="true" fill="currentColor">
								<path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.3-164-39.3c-76 0-103.7 40.8-165.9 40.8s-105.5-57.8-155.5-127.4C46 376.7 0 288.3 0 206 0 86.2 64.1 22.7 190.5 22.7c60.7 0 111.1 20.4 148.7 20.4 35.7 0 90.9-21.5 162.6-21.5 25.2 0 122.4 2.1 194.3 90.3zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"/>
							</svg>
							Continue with Apple
						</button>
					</form>
				</div>
			</>
		)}
	</div>
</BaseLayout>

<style>
	.auth-container {
		max-width: 400px;
		margin: 4rem auto;
	}

	.auth-container h1 {
		font-size: 1.75rem;
		margin-bottom: 0.5rem;
	}

	.subtitle {
		color: var(--sl-color-gray-3);
		margin-bottom: 2rem;
	}

	.auth-form {
		margin-bottom: 1rem;
	}

	.form-group {
		margin-bottom: 1.25rem;
	}

	.form-group label {
		display: block;
		margin-bottom: 0.5rem;
		color: var(--sl-color-gray-3);
		font-size: 0.875rem;
	}

	.form-group input {
		width: 100%;
		padding: 0.75rem 1rem;
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-sm);
		color: var(--sl-color-white);
		font-size: 1rem;
		box-sizing: border-box;
	}

	.form-group input:focus {
		outline: none;
		border-color: var(--sl-color-accent);
	}

	.form-group input::placeholder {
		color: var(--sl-color-gray-4);
	}

	.btn-full {
		width: 100%;
		display: block;
		padding: 0.75rem 1.5rem;
		background: var(--sl-color-accent);
		color: var(--sl-color-white);
		border: none;
		border-radius: var(--tr-radius-sm);
		font-size: 1rem;
		font-weight: 500;
		cursor: pointer;
		transition: filter 0.2s;
	}

	.btn-full:hover {
		filter: brightness(1.1);
	}

	.divider {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin: 1.5rem 0;
		color: var(--sl-color-gray-4);
		font-size: 0.875rem;
	}

	.divider::before,
	.divider::after {
		content: "";
		flex: 1;
		height: 1px;
		background: var(--sl-color-gray-5);
	}

	.oauth-buttons {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.oauth-buttons form {
		margin: 0;
	}

	.btn-oauth {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.625rem;
		padding: 0.75rem 1.5rem;
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		color: var(--sl-color-white);
		border-radius: var(--tr-radius-sm);
		font-size: 1rem;
		font-weight: 500;
		cursor: pointer;
		transition: background 0.2s;
	}

	.btn-oauth:hover {
		background: var(--sl-color-gray-5);
	}

	.error-message {
		background: color-mix(in srgb, var(--tr-color-error) 10%, transparent);
		border: 1px solid var(--tr-color-error);
		color: var(--tr-color-error);
		padding: 0.75rem 1rem;
		border-radius: var(--tr-radius-sm);
		margin-bottom: 1rem;
		font-size: 0.875rem;
	}

	.success-card {
		text-align: center;
		padding: 2rem;
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-md);
	}

	.success-icon {
		font-size: 2.5rem;
		margin-bottom: 0.75rem;
	}

	.success-card h2 {
		font-size: 1.25rem;
		margin-bottom: 0.5rem;
	}

	.success-card p {
		color: var(--sl-color-gray-3);
		margin-bottom: 0.5rem;
		line-height: 1.6;
	}

	.hint {
		font-size: 0.875rem;
	}

	.hint a {
		color: var(--sl-color-accent-high);
	}
</style>
