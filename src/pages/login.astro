---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Sign In" description="Sign in to your True Recall account">
	<div class="auth-container">
		<h1>Sign in to True Recall</h1>
		<p class="subtitle">Manage your subscription and API key.</p>

		<div id="error-banner" class="error-message" style="display:none"></div>

		<div id="success-card" class="success-card" style="display:none">
			<div class="success-icon">✉</div>
			<h2>Check your email</h2>
			<p>We sent a magic link to your inbox. Click it to sign in — no password needed.</p>
			<p class="hint">Didn't receive it? Check your spam folder or <a href="/login">try again</a>.</p>
		</div>

		<form id="login-form" class="auth-form">
			<div class="form-group">
				<label for="email">Email</label>
				<input
					type="email"
					id="email"
					name="email"
					placeholder="you@example.com"
					required
					autocomplete="email"
				/>
			</div>
			<button type="submit" id="submit-btn" class="btn btn-full">Send Magic Link</button>
		</form>
	</div>
</BaseLayout>

<script>
	import { supabase } from "../lib/supabase";

	const form = document.getElementById("login-form") as HTMLFormElement;
	const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
	const errorBanner = document.getElementById("error-banner")!;
	const successCard = document.getElementById("success-card")!;

	form.addEventListener("submit", async (e) => {
		e.preventDefault();
		errorBanner.style.display = "none";

		const email = (document.getElementById("email") as HTMLInputElement).value.trim();
		if (!email) {
			errorBanner.textContent = "Please enter your email address.";
			errorBanner.style.display = "block";
			return;
		}

		submitBtn.disabled = true;
		submitBtn.textContent = "Sending…";

		const { error } = await supabase.auth.signInWithOtp({
			email,
			options: {
				emailRedirectTo: `${window.location.origin}/auth/confirm`,
			},
		});

		if (error) {
			errorBanner.textContent = error.message;
			errorBanner.style.display = "block";
			submitBtn.disabled = false;
			submitBtn.textContent = "Send Magic Link";
		} else {
			form.style.display = "none";
			successCard.style.display = "block";
		}
	});
</script>

<style>
	.auth-container {
		max-width: 400px;
		margin: 4rem auto;
	}

	.auth-container h1 {
		font-size: 1.75rem;
		margin-bottom: 0.5rem;
	}

	.subtitle {
		color: var(--sl-color-gray-3);
		margin-bottom: 2rem;
	}

	.auth-form {
		margin-bottom: 1rem;
	}

	.form-group {
		margin-bottom: 1.25rem;
	}

	.form-group label {
		display: block;
		margin-bottom: 0.5rem;
		color: var(--sl-color-gray-3);
		font-size: 0.875rem;
	}

	.form-group input {
		width: 100%;
		padding: 0.75rem 1rem;
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-sm);
		color: var(--sl-color-white);
		font-size: 1rem;
		box-sizing: border-box;
	}

	.form-group input:focus {
		outline: none;
		border-color: var(--sl-color-accent);
	}

	.form-group input::placeholder {
		color: var(--sl-color-gray-4);
	}

	.btn-full {
		width: 100%;
		display: block;
		padding: 0.75rem 1.5rem;
		background: var(--sl-color-accent);
		color: var(--sl-color-white);
		border: none;
		border-radius: var(--tr-radius-sm);
		font-size: 1rem;
		font-weight: 500;
		cursor: pointer;
		transition: filter 0.2s;
	}

	.btn-full:hover:not(:disabled) {
		filter: brightness(1.1);
	}

	.btn-full:disabled {
		opacity: 0.6;
		cursor: not-allowed;
	}

	.error-message {
		background: color-mix(in srgb, var(--tr-color-error) 10%, transparent);
		border: 1px solid var(--tr-color-error);
		color: var(--tr-color-error);
		padding: 0.75rem 1rem;
		border-radius: var(--tr-radius-sm);
		margin-bottom: 1rem;
		font-size: 0.875rem;
	}

	.success-card {
		text-align: center;
		padding: 2rem;
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-md);
	}

	.success-icon {
		font-size: 2.5rem;
		margin-bottom: 0.75rem;
	}

	.success-card h2 {
		font-size: 1.25rem;
		margin-bottom: 0.5rem;
	}

	.success-card p {
		color: var(--sl-color-gray-3);
		margin-bottom: 0.5rem;
		line-height: 1.6;
	}

	.hint {
		font-size: 0.875rem;
	}

	.hint a {
		color: var(--sl-color-accent-high);
	}
</style>
