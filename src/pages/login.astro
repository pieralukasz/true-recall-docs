---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import { supabase } from "../lib/supabase";

let error = "";
let success = "";

if (Astro.request.method === "POST") {
	const formData = await Astro.request.formData();
	const email = formData.get("email")?.toString() ?? "";
	const password = formData.get("password")?.toString() ?? "";
	const action = formData.get("action")?.toString() ?? "signin";

	if (!email || !password) {
		error = "Email and password are required.";
	} else if (action === "signup") {
		const { error: signUpError } = await supabase.auth.signUp({
			email,
			password,
		});
		if (signUpError) {
			error = signUpError.message;
		} else {
			success = "Check your email for a confirmation link.";
		}
	} else {
		const { data, error: signInError } =
			await supabase.auth.signInWithPassword({ email, password });
		if (signInError) {
			error = signInError.message;
		} else if (data.session) {
			Astro.cookies.set("sb-access-token", data.session.access_token, {
				path: "/",
				httpOnly: true,
				secure: true,
				sameSite: "lax",
				maxAge: 60 * 60 * 24 * 7,
			});
			Astro.cookies.set("sb-refresh-token", data.session.refresh_token, {
				path: "/",
				httpOnly: true,
				secure: true,
				sameSite: "lax",
				maxAge: 60 * 60 * 24 * 30,
			});
			return Astro.redirect("/dashboard");
		}
	}
}
---

<BaseLayout title="Sign In" description="Sign in to your True Recall account">
	<div class="auth-container">
		<h1>Sign in to True Recall</h1>
		<p class="subtitle">Manage your subscription and API key.</p>

		{error && <div class="error-message">{error}</div>}
		{success && <div class="success-message">{success}</div>}

		<form method="POST" class="auth-form">
			<input type="hidden" name="action" value="signin" id="form-action" />

			<div class="form-group">
				<label for="email">Email</label>
				<input
					type="email"
					id="email"
					name="email"
					placeholder="you@example.com"
					required
				/>
			</div>

			<div class="form-group">
				<label for="password">Password</label>
				<input
					type="password"
					id="password"
					name="password"
					placeholder="Your password"
					required
					minlength="6"
				/>
			</div>

			<button type="submit" class="btn btn-full" id="submit-btn">Sign In</button>
		</form>

		<p class="alt-action">
			Don't have an account?
			<a href="#" id="toggle-auth">Create one</a>
		</p>
	</div>
</BaseLayout>

<script>
	const toggleLink = document.getElementById("toggle-auth");
	const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
	const formAction = document.getElementById("form-action") as HTMLInputElement;
	const heading = document.querySelector(".auth-container h1") as HTMLElement;
	const subtitle = document.querySelector(".auth-container .subtitle") as HTMLElement;
	const altAction = document.querySelector(".alt-action") as HTMLElement;

	let isSignUp = false;

	toggleLink?.addEventListener("click", (e) => {
		e.preventDefault();
		isSignUp = !isSignUp;

		if (isSignUp) {
			heading.textContent = "Create an account";
			subtitle.textContent = "Start your True Recall subscription.";
			submitBtn.textContent = "Create Account";
			formAction.value = "signup";
			altAction.innerHTML = 'Already have an account? <a href="#" id="toggle-auth">Sign in</a>';
		} else {
			heading.textContent = "Sign in to True Recall";
			subtitle.textContent = "Manage your subscription and API key.";
			submitBtn.textContent = "Sign In";
			formAction.value = "signin";
			altAction.innerHTML = 'Don\'t have an account? <a href="#" id="toggle-auth">Create one</a>';
		}

		// Re-bind the new toggle link
		document.getElementById("toggle-auth")?.addEventListener("click", arguments.callee as EventListener);
	});
</script>

<style>
	.auth-container {
		max-width: 400px;
		margin: 4rem auto;
	}

	.auth-container h1 {
		font-size: 1.75rem;
		margin-bottom: 0.5rem;
	}

	.subtitle {
		color: var(--sl-color-gray-3);
		margin-bottom: 2rem;
	}

	.auth-form {
		margin-bottom: 1rem;
	}

	.form-group {
		margin-bottom: 1.25rem;
	}

	.form-group label {
		display: block;
		margin-bottom: 0.5rem;
		color: var(--sl-color-gray-3);
		font-size: 0.875rem;
	}

	.form-group input {
		width: 100%;
		padding: 0.75rem 1rem;
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-sm);
		color: var(--sl-color-white);
		font-size: 1rem;
	}

	.form-group input:focus {
		outline: none;
		border-color: var(--sl-color-accent);
	}

	.form-group input::placeholder {
		color: var(--sl-color-gray-4);
	}

	.btn-full {
		width: 100%;
		display: block;
		padding: 0.75rem 1.5rem;
		background: var(--sl-color-accent);
		color: var(--sl-color-white);
		border: none;
		border-radius: var(--tr-radius-sm);
		font-size: 1rem;
		font-weight: 500;
		cursor: pointer;
		transition: filter 0.2s;
	}

	.btn-full:hover {
		filter: brightness(1.1);
	}

	.error-message {
		background: color-mix(in srgb, var(--tr-color-error) 10%, transparent);
		border: 1px solid var(--tr-color-error);
		color: var(--tr-color-error);
		padding: 0.75rem 1rem;
		border-radius: var(--tr-radius-sm);
		margin-bottom: 1rem;
		font-size: 0.875rem;
	}

	.success-message {
		background: color-mix(in srgb, var(--tr-color-success) 10%, transparent);
		border: 1px solid var(--tr-color-success);
		color: var(--tr-color-success);
		padding: 0.75rem 1rem;
		border-radius: var(--tr-radius-sm);
		margin-bottom: 1rem;
		font-size: 0.875rem;
	}

	.alt-action {
		text-align: center;
		color: var(--sl-color-gray-3);
		margin-top: 1.5rem;
	}

	.alt-action a {
		color: var(--sl-color-accent-high);
	}
</style>
