---
import BaseLayout from "../layouts/BaseLayout.astro";

const plans = [
	{
		name: "Free Trial",
		price: "$0",
		period: "no card required",
		description:
			"Sign up to try AI flashcard generation for free. No setup, no credit card.",
		features: [
			"~100 flashcards one-time",
			"No API key or setup needed",
			"No credit card required",
		],
		cta: "Start Free Trial",
		ctaHref: "/login",
		popular: false,
		secondary: false,
	},
	{
		name: "Pro",
		price: "$2",
		period: "/month",
		description:
			"AI study assistant — optimized generation, smart coaching, leech fixing, and more. No setup, no hassle.",
		features: [
			"~2,000–3,000 flashcards per month",
			"Perfectly tuned prompts for learning",
			"AI Study Coach & Leech Doctor",
			"Knowledge Base chat",
			"No API key or setup needed",
			"Cancel anytime",
		],
		cta: "Subscribe",
		ctaHref: "/login",
		popular: true,
		secondary: false,
	},
	{
		name: "BYOK",
		price: "Free",
		period: "forever",
		description:
			"Use your own OpenRouter API key and prompts. Full control — you manage everything yourself.",
		features: [
			"Unlimited flashcard generation",
			"Use any supported model",
			"Bring your own prompts",
			"Pay OpenRouter directly",
		],
		cta: "Get Started",
		ctaHref: "/getting-started/quick-start/",
		popular: false,
		secondary: true,
	},
];

---

<BaseLayout
	title="Pricing"
	description="True Recall subscription plans for AI-powered flashcard generation"
>
	<div class="credits">
		<h1>Simple, transparent pricing</h1>
		<p>
			Expert AI flashcard generation with perfectly tuned prompts. Or bring
			your own key — it's free.
		</p>

		<div class="plans">
			{
				plans.map((plan) => (
					<div class:list={["plan", { popular: plan.popular }]}>
						{plan.popular && (
							<span class="badge">Most Popular</span>
						)}
						<h2>{plan.name}</h2>
						<div class="price">
							{plan.price}
							<span class="period">{plan.period}</span>
						</div>
						<p>{plan.description}</p>
						<ul class="features">
							{plan.features.map((f) => (
								<li>{f}</li>
							))}
						</ul>
						<a
							href={plan.ctaHref}
							class:list={[
								"btn",
								{ "btn-secondary": plan.secondary },
							]}
						>
							{plan.cta}
						</a>
					</div>
				))
			}
		</div>

		<p class="note">
			Flashcard counts are approximate. The number of flashcards per
			generation depends on how much text you select and how dense the
			content is — select a whole note and expect significantly more cards.
		</p>
	</div>

</BaseLayout>

<style>
	/* Reuse .credits, .plans, .plan from custom.css — extend here */
	.credits {
		text-align: center;
		max-width: 900px;
		margin: 0 auto;
		padding-top: 2rem;
	}

	.credits h1 {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
	}

	.credits > p {
		color: var(--sl-color-gray-3);
		margin-bottom: 3rem;
		font-size: 1.125rem;
	}

	.plans {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
		margin-bottom: 2rem;
		text-align: left;
	}

	.plan {
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-md);
		padding: 2rem;
		position: relative;
		display: flex;
		flex-direction: column;
	}

	.plan.popular {
		border-color: var(--sl-color-accent);
	}

	.plan .badge {
		position: absolute;
		top: -10px;
		left: 50%;
		transform: translateX(-50%);
		background: var(--sl-color-accent);
		color: var(--sl-color-white);
		padding: 0.25rem 0.75rem;
		border-radius: var(--tr-radius-pill);
		font-size: 0.75rem;
		font-weight: 600;
		white-space: nowrap;
	}

	.plan h2 {
		font-size: 1.5rem;
		margin-bottom: 0.5rem;
		min-height: 2.25rem;
	}

	.price {
		font-size: 2.5rem;
		font-weight: 700;
		color: var(--sl-color-accent);
		margin-bottom: 0.5rem;
		display: flex;
		align-items: baseline;
		gap: 0.25rem;
		min-height: 3.5rem;
	}

	.price .period {
		font-size: 1rem;
		font-weight: 400;
		color: var(--sl-color-gray-3);
	}

	.plan > p {
		color: var(--sl-color-gray-3);
		margin-bottom: 1.5rem;
		font-size: 0.875rem;
		min-height: 2.75rem;
	}

	.features {
		list-style: none;
		margin-bottom: 2rem;
		flex: 1;
	}

	.features li {
		padding: 0.375rem 0;
		padding-left: 1.5rem;
		position: relative;
		font-size: 0.9375rem;
		color: var(--sl-color-gray-2);
	}

	.features li::before {
		content: "✓";
		position: absolute;
		left: 0;
		color: var(--tr-color-success);
		font-weight: 600;
	}

	.btn {
		display: block;
		text-align: center;
		padding: 0.75rem 1.5rem;
		background: var(--sl-color-accent);
		color: var(--sl-color-white);
		border: none;
		border-radius: var(--tr-radius-sm);
		font-size: 1rem;
		font-weight: 500;
		cursor: pointer;
		transition: filter 0.2s;
		text-decoration: none;
		margin-top: auto;
	}

	.btn:hover {
		filter: brightness(1.1);
		text-decoration: none;
	}

	.btn-secondary {
		background: transparent;
		border: 1px solid var(--sl-color-gray-5);
	}

	.btn-secondary:hover {
		background: var(--sl-color-gray-6);
	}

	.note {
		color: var(--sl-color-gray-4);
		font-size: 0.875rem;
	}

	@media (max-width: 768px) {
		.plans {
			grid-template-columns: 1fr;
		}

		.plan h2,
		.price,
		.plan > p {
			min-height: unset;
		}
	}
</style>

<script>
	// Redirect pricing CTAs to dashboard for logged-in users
	if (document.documentElement.classList.contains("is-logged-in")) {
		document.querySelectorAll<HTMLAnchorElement>('a.btn[href="/login"]').forEach((a) => {
			a.href = "/dashboard";
		});
	}
</script>
