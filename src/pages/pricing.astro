---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
	POLAR_STARTER_CHECKOUT_URL,
	POLAR_TOPUP_S_CHECKOUT_URL,
	POLAR_TOPUP_M_CHECKOUT_URL,
} from "../lib/constants";

const plans = [
	{
		name: "Free",
		price: "$0",
		period: "forever",
		description: "Use your own OpenRouter API key. Full AI access, no limits.",
		features: [
			"Bring your own API key (BYOK)",
			"Full AI flashcard generation",
			"Unlimited usage",
			"Pay only for what you use on OpenRouter",
		],
		cta: "Get Started",
		ctaHref: "/getting-started/installation",
		popular: false,
		secondary: true,
	},
	{
		name: "Starter",
		price: "$7",
		period: "/month",
		description: "~350 AI generations per month. No API key needed. Free trial on signup.",
		features: [
			"~350 AI generations per month",
			"No API key or setup needed",
			"Usage dashboard",
			"Free trial (~50 generations)",
		],
		cta: "Subscribe",
		ctaHref: POLAR_STARTER_CHECKOUT_URL,
		popular: true,
		secondary: false,
	},
];

const topups = [
	{
		name: "Top-up S",
		price: "$4.99",
		description: "~280 extra generations",
		href: POLAR_TOPUP_S_CHECKOUT_URL,
	},
	{
		name: "Top-up M",
		price: "$9.99",
		description: "~640 extra generations",
		href: POLAR_TOPUP_M_CHECKOUT_URL,
	},
];

const faqs = [
	{
		q: "How many generations do I get?",
		a: "The Starter plan includes ~350 AI generations per month. Each generation creates a set of flashcards from your selected text.",
	},
	{
		q: "Can I still use my own API key?",
		a: "Absolutely! The Free tier lets you use your own OpenRouter API key with no restrictions. The Starter plan is for users who prefer a managed, no-setup experience.",
	},
	{
		q: "What happens when I run out of generations?",
		a: "You'll see a notification in the plugin. You can buy a top-up, wait for the monthly reset, or switch to your own API key.",
	},
	{
		q: "Can I cancel anytime?",
		a: "Yes. Cancel anytime from your dashboard. You'll keep access until the end of your billing period.",
	},
	{
		q: "How do I activate my subscription in Obsidian?",
		a: "After subscribing, you'll get a subscription key on your dashboard. Paste it into True Recall settings → AI → Subscription Key. That's it!",
	},
	{
		q: "What's the free trial?",
		a: "Every new account gets ~50 free AI generations. No payment required. Try it before subscribing.",
	},
];
---

<BaseLayout title="Pricing" description="True Recall subscription plans for AI-powered flashcard generation">
	<div class="credits">
		<h1>Simple, transparent pricing</h1>
		<p>Generate AI flashcards without managing API keys. Or bring your own — it's free.</p>

		<div class="plans">
			{plans.map((plan) => (
				<div class:list={["plan", { popular: plan.popular }]}>
					{plan.popular && <span class="badge">Most Popular</span>}
					<h2>{plan.name}</h2>
					<div class="price">
						{plan.price}<span class="period">{plan.period}</span>
					</div>
					<p>{plan.description}</p>
					<ul class="features">
						{plan.features.map((f) => (
							<li>{f}</li>
						))}
					</ul>
					<a
						href={plan.ctaHref}
						class:list={["btn", { "btn-secondary": plan.secondary }]}
					>
						{plan.cta}
					</a>
				</div>
			))}
		</div>

		<p class="note">
			Generation counts are approximate and may vary slightly based on text length.
		</p>

		<div class="topup-section">
			<h2>Need more budget?</h2>
			<p>Top up anytime without changing your plan.</p>
			<div class="topup-grid">
				{topups.map((t) => (
					<div class="topup-card">
						<div class="topup-name">{t.name}</div>
						<div class="topup-price">{t.price}</div>
						<div class="topup-budget">{t.description}</div>
						<a href={t.href} class="btn btn-secondary topup-btn">Buy</a>
					</div>
				))}
			</div>
		</div>
	</div>

	<div class="faq-section">
		<h2>Frequently Asked Questions</h2>
		<div class="faq-list">
			{faqs.map((faq) => (
				<details class="faq-item">
					<summary>{faq.q}</summary>
					<p>{faq.a}</p>
				</details>
			))}
		</div>
	</div>
</BaseLayout>

<style>
	/* Reuse .credits, .plans, .plan from custom.css — extend here */
	.credits {
		text-align: center;
		max-width: 900px;
		margin: 0 auto;
		padding-top: 2rem;
	}

	.credits h1 {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
	}

	.credits > p {
		color: var(--sl-color-gray-3);
		margin-bottom: 3rem;
		font-size: 1.125rem;
	}

	.plans {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 1.5rem;
		margin-bottom: 2rem;
		text-align: left;
	}

	.plan {
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-md);
		padding: 2rem;
		position: relative;
		display: flex;
		flex-direction: column;
	}

	.plan.popular {
		border-color: var(--sl-color-accent);
	}

	.plan .badge {
		position: absolute;
		top: -10px;
		left: 50%;
		transform: translateX(-50%);
		background: var(--sl-color-accent);
		color: var(--sl-color-white);
		padding: 0.25rem 0.75rem;
		border-radius: var(--tr-radius-pill);
		font-size: 0.75rem;
		font-weight: 600;
		white-space: nowrap;
	}

	.plan h2 {
		font-size: 1.5rem;
		margin-bottom: 0.5rem;
	}

	.price {
		font-size: 2.5rem;
		font-weight: 700;
		color: var(--sl-color-accent);
		margin-bottom: 0.5rem;
	}

	.price .period {
		font-size: 1rem;
		font-weight: 400;
		color: var(--sl-color-gray-3);
	}

	.plan > p {
		color: var(--sl-color-gray-3);
		margin-bottom: 1.5rem;
		font-size: 0.875rem;
	}

	.features {
		list-style: none;
		margin-bottom: 2rem;
		flex: 1;
	}

	.features li {
		padding: 0.375rem 0;
		padding-left: 1.5rem;
		position: relative;
		font-size: 0.9375rem;
		color: var(--sl-color-gray-2);
	}

	.features li::before {
		content: "✓";
		position: absolute;
		left: 0;
		color: var(--tr-color-success);
		font-weight: 600;
	}

	.btn {
		display: block;
		text-align: center;
		padding: 0.75rem 1.5rem;
		background: var(--sl-color-accent);
		color: var(--sl-color-white);
		border: none;
		border-radius: var(--tr-radius-sm);
		font-size: 1rem;
		font-weight: 500;
		cursor: pointer;
		transition: filter 0.2s;
		text-decoration: none;
	}

	.btn:hover {
		filter: brightness(1.1);
		text-decoration: none;
	}

	.btn-secondary {
		background: transparent;
		border: 1px solid var(--sl-color-gray-5);
	}

	.btn-secondary:hover {
		background: var(--sl-color-gray-6);
	}

	.note {
		color: var(--sl-color-gray-4);
		font-size: 0.875rem;
	}

	/* Top-up Section */
	.topup-section {
		text-align: center;
		margin-top: 3rem;
	}

	.topup-section h2 {
		font-size: 1.5rem;
		margin-bottom: 0.5rem;
	}

	.topup-section > p {
		color: var(--sl-color-gray-3);
		margin-bottom: 1.5rem;
	}

	.topup-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1rem;
		max-width: 500px;
		margin: 0 auto;
	}

	.topup-card {
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-md);
		padding: 1.5rem;
		text-align: center;
	}

	.topup-name {
		font-weight: 600;
		margin-bottom: 0.5rem;
	}

	.topup-price {
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--sl-color-accent);
		margin-bottom: 0.25rem;
	}

	.topup-budget {
		color: var(--sl-color-gray-3);
		font-size: 0.875rem;
		margin-bottom: 1rem;
	}

	.topup-btn {
		width: 100%;
	}

	/* FAQ Section */
	.faq-section {
		max-width: 700px;
		margin: 4rem auto 0;
	}

	.faq-section h2 {
		font-size: 1.75rem;
		margin-bottom: 1.5rem;
		text-align: center;
	}

	.faq-list {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.faq-item {
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-sm);
		padding: 1rem 1.25rem;
	}

	.faq-item summary {
		cursor: pointer;
		font-weight: 500;
		font-size: 1rem;
		list-style: none;
	}

	.faq-item summary::-webkit-details-marker {
		display: none;
	}

	.faq-item summary::before {
		content: "+";
		display: inline-block;
		width: 1.25rem;
		font-weight: 600;
		color: var(--sl-color-accent);
	}

	.faq-item[open] summary::before {
		content: "−";
	}

	.faq-item p {
		margin-top: 0.75rem;
		color: var(--sl-color-gray-3);
		font-size: 0.9375rem;
		line-height: 1.6;
		padding-left: 1.25rem;
	}
</style>
