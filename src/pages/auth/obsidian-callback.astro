---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Returning to Obsidian" description="Redirecting back to the True Recall plugin">
	<div class="confirm-container">
		<div id="redirecting">
			<h1>Returning to Obsidian…</h1>
			<p>You should be redirected back to the plugin automatically.</p>
		</div>
		<div id="fallback" style="display:none">
			<h1>Almost there!</h1>
			<p>If Obsidian didn't open automatically, click the button below.</p>
			<a id="obsidian-link" href="#" class="btn">Open in Obsidian</a>
		</div>
		<div id="error-state" style="display:none">
			<h1>Something went wrong</h1>
			<p class="error-message">No authentication code received. Please try signing in again from the plugin.</p>
		</div>
	</div>
</BaseLayout>

<script>
	const params = new URLSearchParams(window.location.search);
	const code = params.get("code");

	const redirectingEl = document.getElementById("redirecting")!;
	const fallbackEl = document.getElementById("fallback")!;
	const errorEl = document.getElementById("error-state")!;
	const obsidianLink = document.getElementById("obsidian-link") as HTMLAnchorElement;

	if (code) {
		const obsidianUrl = `obsidian://true-recall-auth?code=${encodeURIComponent(code)}`;
		obsidianLink.href = obsidianUrl;

		// Try to redirect immediately
		window.location.href = obsidianUrl;

		// Show manual fallback after a short delay in case redirect didn't work
		setTimeout(() => {
			redirectingEl.style.display = "none";
			fallbackEl.style.display = "block";
		}, 2000);
	} else {
		redirectingEl.style.display = "none";
		errorEl.style.display = "block";
	}
</script>

<style>
	.confirm-container {
		max-width: 400px;
		margin: 6rem auto;
		text-align: center;
	}

	.confirm-container h1 {
		font-size: 1.75rem;
		margin-bottom: 1rem;
	}

	.confirm-container p {
		color: var(--sl-color-gray-3);
		margin-bottom: 1.5rem;
	}

	.error-message {
		background: color-mix(in srgb, var(--tr-color-error) 10%, transparent);
		border: 1px solid var(--tr-color-error);
		color: var(--tr-color-error);
		padding: 0.75rem 1rem;
		border-radius: var(--tr-radius-sm);
		font-size: 0.875rem;
	}

	.btn {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		background: var(--sl-color-accent);
		color: var(--sl-color-white);
		border: none;
		border-radius: var(--tr-radius-sm);
		font-size: 1rem;
		font-weight: 500;
		cursor: pointer;
		transition: filter 0.2s;
		text-decoration: none;
	}

	.btn:hover {
		filter: brightness(1.1);
		text-decoration: none;
	}
</style>
