---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { supabase } from "../../lib/supabase";

const tokenHash = Astro.url.searchParams.get("token_hash");
const type = Astro.url.searchParams.get("type") as "email" | "recovery" | "magiclink" | undefined;

let error = "";

if (tokenHash && type) {
	const { data, error: verifyError } = await supabase.auth.verifyOtp({
		token_hash: tokenHash,
		type,
	});

	if (verifyError) {
		error = verifyError.message;
	} else if (data.session) {
		Astro.cookies.set("sb-access-token", data.session.access_token, {
			path: "/",
			httpOnly: true,
			secure: true,
			sameSite: "lax",
			maxAge: 60 * 60 * 24 * 7,
		});
		Astro.cookies.set("sb-refresh-token", data.session.refresh_token, {
			path: "/",
			httpOnly: true,
			secure: true,
			sameSite: "lax",
			maxAge: 60 * 60 * 24 * 30,
		});
		return Astro.redirect("/dashboard");
	} else {
		error = "Email confirmed but no session was created. Please sign in.";
	}
} else {
	error = "This link is invalid or has expired. Please request a new sign-in link.";
}
---

<BaseLayout title="Email Confirmation" description="Confirm your True Recall email address">
	<div class="confirm-container">
		{error ? (
			<>
				<h1>Confirmation Failed</h1>
				<p class="error-message">{error}</p>
				<a href="/login" class="btn">Go to Sign In</a>
			</>
		) : (
			<>
				<h1>Confirming...</h1>
				<p>Please wait while we verify your email.</p>
			</>
		)}
	</div>
</BaseLayout>

<style>
	.confirm-container {
		max-width: 400px;
		margin: 6rem auto;
		text-align: center;
	}

	.confirm-container h1 {
		font-size: 1.75rem;
		margin-bottom: 1rem;
	}

	.confirm-container p {
		color: var(--sl-color-gray-3);
		margin-bottom: 1.5rem;
	}

	.error-message {
		background: color-mix(in srgb, var(--tr-color-error) 10%, transparent);
		border: 1px solid var(--tr-color-error);
		color: var(--tr-color-error);
		padding: 0.75rem 1rem;
		border-radius: var(--tr-radius-sm);
		font-size: 0.875rem;
	}

	.btn {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		background: var(--sl-color-accent);
		color: var(--sl-color-white);
		border: none;
		border-radius: var(--tr-radius-sm);
		font-size: 1rem;
		font-weight: 500;
		cursor: pointer;
		transition: filter 0.2s;
		text-decoration: none;
	}

	.btn:hover {
		filter: brightness(1.1);
		text-decoration: none;
	}
</style>
