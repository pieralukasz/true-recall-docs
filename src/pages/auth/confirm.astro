---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { createSupabaseServerClient } from "../../lib/supabase-server";
import { setSessionCookies } from "../../lib/auth-helpers";

const supabase = createSupabaseServerClient(
	Astro.cookies,
	Astro.request.headers.get("cookie"),
);

const code = Astro.url.searchParams.get("code");
const tokenHash = Astro.url.searchParams.get("token_hash");
const rawType = Astro.url.searchParams.get("type");
const ALLOWED_OTP_TYPES = ["email", "recovery", "magiclink"] as const;
type OtpType = (typeof ALLOWED_OTP_TYPES)[number];
const type: OtpType | undefined = ALLOWED_OTP_TYPES.includes(rawType as OtpType)
	? (rawType as OtpType)
	: undefined;

let error = "";

if (code) {
	// PKCE flow
	const { data, error: exchangeError } = await supabase.auth.exchangeCodeForSession(code);

	if (exchangeError) {
		error = exchangeError.message;
	} else if (data.session) {
		setSessionCookies(Astro.cookies, data.session);
		return Astro.redirect("/dashboard");
	} else {
		error = "Email confirmed but no session was created. Please sign in.";
	}
} else if (tokenHash && type) {
	const { data, error: verifyError } = await supabase.auth.verifyOtp({
		token_hash: tokenHash,
		type,
	});

	if (verifyError) {
		error = verifyError.message;
	} else if (data.session) {
		setSessionCookies(Astro.cookies, data.session);
		return Astro.redirect("/dashboard");
	} else {
		error = "Email confirmed but no session was created. Please sign in.";
	}
} else {
	error = "This link is invalid or has expired. Please request a new sign-in link.";
}
---

<BaseLayout title="Email Confirmation" description="Confirm your True Recall email address">
	<div class="confirm-container">
		{error ? (
			<>
				<h1>Confirmation Failed</h1>
				<p class="error-message">{error}</p>
				<a href="/login" class="btn">Go to Sign In</a>
			</>
		) : (
			<>
				<h1>Confirming...</h1>
				<p>Please wait while we verify your email.</p>
			</>
		)}
	</div>
</BaseLayout>

<style>
	.confirm-container {
		max-width: 400px;
		margin: 6rem auto;
		text-align: center;
	}

	.confirm-container h1 {
		font-size: 1.75rem;
		margin-bottom: 1rem;
	}

	.confirm-container p {
		color: var(--sl-color-gray-3);
		margin-bottom: 1.5rem;
	}

	.error-message {
		background: color-mix(in srgb, var(--tr-color-error) 10%, transparent);
		border: 1px solid var(--tr-color-error);
		color: var(--tr-color-error);
		padding: 0.75rem 1rem;
		border-radius: var(--tr-radius-sm);
		font-size: 0.875rem;
	}

	.btn {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		background: var(--sl-color-accent);
		color: var(--sl-color-white);
		border: none;
		border-radius: var(--tr-radius-sm);
		font-size: 1rem;
		font-weight: 500;
		cursor: pointer;
		transition: filter 0.2s;
		text-decoration: none;
	}

	.btn:hover {
		filter: brightness(1.1);
		text-decoration: none;
	}
</style>
