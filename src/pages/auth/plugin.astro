---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { createSupabaseServerClient } from "../../lib/supabase-server";
import { getSupabaseAdmin } from "../../lib/supabase-admin";
import { generateKey } from "../../lib/litellm";
import { canonicalizeEmail } from "../../lib/email";
import { TIER_BUDGETS, MANAGED_MODELS, SITE_URL } from "../../lib/constants";

const supabase = createSupabaseServerClient(
	Astro.cookies,
	Astro.request.headers.get("cookie"),
);

const state = Astro.url.searchParams.get("state") ?? "";

if (!state) {
	return Astro.redirect("/login");
}

let error = "";
let emailSent = false;
let redirectUrl = "";
let fallbackKey = "";

// Check if user is already logged in
const accessToken = Astro.cookies.get("sb-access-token")?.value;
const refreshToken = Astro.cookies.get("sb-refresh-token")?.value;
let user: { id: string; email?: string } | null = null;

if (accessToken) {
	const { data: { user: authUser }, error: authError } = await supabase.auth.getUser(accessToken);
	if (!authError && authUser) {
		user = authUser;
	} else if (refreshToken) {
		const { data: refreshData, error: refreshError } =
			await supabase.auth.refreshSession({ refresh_token: refreshToken });
		if (!refreshError && refreshData.session) {
			Astro.cookies.set("sb-access-token", refreshData.session.access_token, {
				path: "/",
				httpOnly: true,
				secure: true,
				sameSite: "lax",
				maxAge: 60 * 60 * 24 * 7,
			});
			Astro.cookies.set("sb-refresh-token", refreshData.session.refresh_token, {
				path: "/",
				httpOnly: true,
				secure: true,
				sameSite: "lax",
				maxAge: 60 * 60 * 24 * 30,
			});
			user = refreshData.session.user;
		}
	}
}

// If user is logged in, generate code and prepare redirect
if (user) {
	try {
		// Ensure user has a subscription (auto-provision trial if needed)
		let { data: subscription } = await supabase
			.from("user_subscriptions")
			.select("*")
			.eq("user_id", user.id)
			.single();

		if (!subscription?.litellm_api_key && !subscription?.trial_used) {
			const canonical = canonicalizeEmail(user.email ?? "");
			const clientIp = Astro.request.headers.get("x-forwarded-for")?.split(",")[0]?.trim() ?? "unknown";

			const { count: canonicalCount } = await supabase
				.from("user_subscriptions")
				.select("*", { count: "exact", head: true })
				.eq("canonical_email", canonical)
				.eq("trial_used", true);

			const since = new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString();
			const { count: ipCount } = await supabase
				.from("user_subscriptions")
				.select("*", { count: "exact", head: true })
				.eq("trial_ip", clientIp)
				.gte("created_at", since)
				.eq("trial_used", true);

			if ((canonicalCount ?? 0) > 0 || (ipCount ?? 0) >= 3) {
				error = "Trial already used for this account. Please subscribe for continued access.";
			} else {
				const keyResult = await generateKey({
					userId: user.id,
					maxBudget: TIER_BUDGETS.trial ?? 0.35,
					metadata: { tier: "trial", email: user.email ?? "" },
					models: MANAGED_MODELS,
				});
				await supabase.from("user_subscriptions").upsert({
					user_id: user.id,
					tier: "trial",
					litellm_key_hash: keyResult.token,
					litellm_api_key: keyResult.key,
					trial_used: true,
					canonical_email: canonical,
					trial_ip: clientIp,
					updated_at: new Date().toISOString(),
				});
				subscription = {
					...subscription,
					tier: "trial",
					litellm_api_key: keyResult.key,
					litellm_key_hash: keyResult.token,
					trial_used: true,
				};
			}
		}

		if (subscription?.litellm_api_key && !error) {
			// Generate one-time auth code (use admin client — RLS blocks anon access)
			const code = crypto.randomUUID();
			const adminClient = getSupabaseAdmin();
			await adminClient.from("auth_codes").insert({
				code,
				user_id: user.id,
				state,
				expires_at: new Date(Date.now() + 5 * 60 * 1000).toISOString(),
			});
			redirectUrl = `obsidian://true-recall-auth?code=${encodeURIComponent(code)}&state=${encodeURIComponent(state)}`;
			fallbackKey = subscription.litellm_api_key;
		} else if (!error) {
			error = "No subscription found. Please subscribe first.";
		}
	} catch (err) {
		console.error("Plugin auth error:", err);
		error = "Something went wrong. Please try again.";
	}
}

// Handle magic link submission for non-logged-in users
if (!user && Astro.request.method === "POST") {
	const formData = await Astro.request.formData();
	const action = formData.get("action")?.toString();

	if (action === "magic-link") {
		const email = formData.get("email")?.toString().trim() ?? "";
		if (!email) {
			error = "Please enter your email address.";
		} else {
			const { error: otpError } = await supabase.auth.signInWithOtp({
				email,
				options: {
					emailRedirectTo: `${SITE_URL}/auth/plugin-confirm?state=${encodeURIComponent(state)}`,
				},
			});
			if (otpError) {
				error = otpError.message;
			} else {
				emailSent = true;
			}
		}
	}
}
---

<BaseLayout title="Sign In to True Recall" description="Connect your Obsidian plugin to True Recall">
	<div class="plugin-auth-container">
		{redirectUrl ? (
			<div class="success-card">
				<div class="success-icon">&#10003;</div>
				<h2>Signed in!</h2>
				<p>Redirecting to Obsidian...</p>
				<a href={redirectUrl} class="btn btn-full" id="open-obsidian">Open Obsidian</a>
				<div class="fallback">
					<p class="hint">If Obsidian didn't open, copy your key manually:</p>
					<div class="key-display">
						<code id="api-key">{fallbackKey}</code>
						<button class="btn-copy" id="copy-key" type="button">Copy</button>
					</div>
				</div>
			</div>
		) : error && user ? (
			<>
				<h1>Sign In</h1>
				<div class="error-message">{error}</div>
				<a href="/pricing" class="btn btn-full">View Plans</a>
			</>
		) : emailSent ? (
			<div class="success-card">
				<div class="success-icon">&#9993;</div>
				<h2>Check your email</h2>
				<p>We sent a magic link to your inbox. Click it to sign in and connect your plugin.</p>
				<p class="hint">Didn't receive it? Check spam or <a href={`/auth/plugin?state=${encodeURIComponent(state)}`}>try again</a>.</p>
			</div>
		) : !user ? (
			<>
				<h1>Sign in to True Recall</h1>
				<p class="subtitle">Connect your Obsidian plugin for AI-powered flashcards.</p>

				{error && <div class="error-message">{error}</div>}

				<form method="POST" class="auth-form">
					<input type="hidden" name="action" value="magic-link" />
					<div class="form-group">
						<label for="email">Email</label>
						<input
							type="email"
							id="email"
							name="email"
							placeholder="you@example.com"
							required
							autocomplete="email"
						/>
					</div>
					<button type="submit" class="btn btn-full">Send Magic Link</button>
				</form>
			</>
		) : null}
	</div>
</BaseLayout>

<script define:vars={{ redirectUrl }}>
	if (redirectUrl) {
		// Auto-redirect to Obsidian
		window.location.href = redirectUrl;

		// Copy key to clipboard
		const copyBtn = document.getElementById("copy-key");
		const keyEl = document.getElementById("api-key");
		if (copyBtn && keyEl) {
			copyBtn.addEventListener("click", () => {
				navigator.clipboard.writeText(keyEl.textContent ?? "").then(() => {
					copyBtn.textContent = "Copied!";
					setTimeout(() => { copyBtn.textContent = "Copy"; }, 2000);
				});
			});
		}
	}
</script>

<style>
	.plugin-auth-container {
		max-width: 400px;
		margin: 4rem auto;
	}

	.plugin-auth-container h1 {
		font-size: 1.75rem;
		margin-bottom: 0.5rem;
	}

	.subtitle {
		color: var(--sl-color-gray-3);
		margin-bottom: 2rem;
	}

	.auth-form {
		margin-bottom: 1rem;
	}

	.form-group {
		margin-bottom: 1.25rem;
	}

	.form-group label {
		display: block;
		margin-bottom: 0.5rem;
		color: var(--sl-color-gray-3);
		font-size: 0.875rem;
	}

	.form-group input {
		width: 100%;
		padding: 0.75rem 1rem;
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-sm);
		color: var(--sl-color-white);
		font-size: 1rem;
		box-sizing: border-box;
	}

	.form-group input:focus {
		outline: none;
		border-color: var(--sl-color-accent);
	}

	.form-group input::placeholder {
		color: var(--sl-color-gray-4);
	}

	.btn {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		background: var(--sl-color-accent);
		color: var(--sl-color-white);
		border: none;
		border-radius: var(--tr-radius-sm);
		font-size: 1rem;
		font-weight: 500;
		cursor: pointer;
		transition: filter 0.2s;
		text-decoration: none;
		text-align: center;
	}

	.btn:hover {
		filter: brightness(1.1);
		text-decoration: none;
	}

	.btn-full {
		width: 100%;
		display: block;
	}

	.error-message {
		background: color-mix(in srgb, var(--tr-color-error) 10%, transparent);
		border: 1px solid var(--tr-color-error);
		color: var(--tr-color-error);
		padding: 0.75rem 1rem;
		border-radius: var(--tr-radius-sm);
		margin-bottom: 1rem;
		font-size: 0.875rem;
	}

	.success-card {
		text-align: center;
		padding: 2rem;
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-md);
	}

	.success-icon {
		font-size: 2.5rem;
		margin-bottom: 0.75rem;
	}

	.success-card h2 {
		font-size: 1.25rem;
		margin-bottom: 0.5rem;
	}

	.success-card p {
		color: var(--sl-color-gray-3);
		margin-bottom: 0.5rem;
		line-height: 1.6;
	}

	.hint {
		font-size: 0.875rem;
		color: var(--sl-color-gray-4);
	}

	.hint a {
		color: var(--sl-color-accent-high);
	}

	.fallback {
		margin-top: 1.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--sl-color-gray-5);
	}

	.key-display {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-top: 0.75rem;
		padding: 0.5rem 0.75rem;
		background: var(--sl-color-gray-7, var(--sl-color-black));
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-sm);
	}

	.key-display code {
		flex: 1;
		font-size: 0.8rem;
		word-break: break-all;
		text-align: left;
		color: var(--sl-color-gray-2);
	}

	.btn-copy {
		padding: 0.375rem 0.75rem;
		background: var(--sl-color-gray-5);
		color: var(--sl-color-white);
		border: none;
		border-radius: var(--tr-radius-sm);
		font-size: 0.8rem;
		cursor: pointer;
		white-space: nowrap;
	}

	.btn-copy:hover {
		background: var(--sl-color-gray-4);
	}
</style>
