---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { createSupabaseServerClient } from "../../lib/supabase-server";
import { getSupabaseAdmin } from "../../lib/supabase-admin";
import { SITE_URL } from "../../lib/constants";
import { resolveUser } from "../../lib/auth-helpers";
import { provisionTrial } from "../../lib/trial-provisioning";

const supabase = createSupabaseServerClient(
	Astro.cookies,
	Astro.request.headers.get("cookie"),
);

const state = Astro.url.searchParams.get("state") ?? "";

if (!state) {
	return Astro.redirect("/login");
}

let error = "";
let emailSent = false;
let redirectUrl = "";

const user = await resolveUser(Astro.cookies, supabase);

// Logged-in user clicks "Authorize" → generate code and redirect
if (user && Astro.request.method === "POST") {
	const formData = await Astro.request.formData();
	const action = formData.get("action")?.toString();

	if (action === "authorize") {
		try {
			const clientIp = Astro.request.headers.get("x-forwarded-for")?.split(",")[0]?.trim() ?? "unknown";
			const trial = await provisionTrial(supabase, user, clientIp);

			if (trial.blocked) {
				error = trial.error ?? "Trial already used for this account. Please subscribe for continued access.";
			} else if (trial.success && trial.subscription?.litellm_api_key) {
				const code = crypto.randomUUID();
				const adminClient = getSupabaseAdmin();
				const { error: insertError } = await adminClient.from("auth_codes").insert({
					code,
					user_id: user.id,
					state,
					expires_at: new Date(Date.now() + 5 * 60 * 1000).toISOString(),
				});
				if (insertError) {
					console.error("auth_codes insert failed:", insertError);
					error = `Authorization failed: ${insertError.message}`;
				} else {
					redirectUrl = `obsidian://true-recall-auth?code=${encodeURIComponent(code)}&state=${encodeURIComponent(state)}`;
				}
			} else {
				error = "No subscription found. Please subscribe first.";
			}
		} catch (err) {
			console.error("Plugin auth error:", err);
			error = `Something went wrong: ${err instanceof Error ? err.message : String(err)}`;
		}
	}
}

// Not logged in → magic link
if (!user && Astro.request.method === "POST") {
	const formData = await Astro.request.formData();
	const action = formData.get("action")?.toString();

	if (action === "magic-link") {
		const email = formData.get("email")?.toString().trim() ?? "";
		if (!email) {
			error = "Please enter your email address.";
		} else {
			const { error: otpError } = await supabase.auth.signInWithOtp({
				email,
				options: {
					emailRedirectTo: `${SITE_URL}/auth/plugin-confirm?state=${encodeURIComponent(state)}`,
				},
			});
			if (otpError) {
				error = otpError.message;
			} else {
				emailSent = true;
			}
		}
	}
}
---

<BaseLayout title="Sign In to True Recall" description="Connect your Obsidian plugin to True Recall">
	<div class="plugin-auth-container">
		{redirectUrl ? (
			<div class="success-card">
				<div class="success-icon">&#10003;</div>
				<h2>Authorized!</h2>
				<p>Redirecting to Obsidian...</p>
				<a href={redirectUrl} class="btn btn-full" id="open-obsidian">Open Obsidian</a>
				<p class="hint" style="margin-top: 1rem;">If nothing happens, click the button above.</p>
			</div>
		) : user && error ? (
			<>
				<h1>Authorization Failed</h1>
				<div class="error-message">{error}</div>
				<a href="/pricing" class="btn btn-full">View Plans</a>
			</>
		) : user ? (
			<div class="authorize-card">
				<h2>Authorize Plugin</h2>
				<p>Connect your Obsidian plugin to your True Recall account.</p>
				<div class="user-info">
					<span class="user-email">{user.email}</span>
				</div>
				<form method="POST">
					<input type="hidden" name="action" value="authorize" />
					<button type="submit" class="btn btn-full">Authorize</button>
				</form>
				<p class="hint">Not you? <a href="/login">Sign in with a different account</a>.</p>
			</div>
		) : emailSent ? (
			<div class="success-card">
				<div class="success-icon">&#9993;</div>
				<h2>Check your email</h2>
				<p>We sent a magic link to your inbox. Click it to sign in and connect your plugin.</p>
				<p class="hint">Didn't receive it? Check spam or <a href={`/auth/plugin?state=${encodeURIComponent(state)}`}>try again</a>.</p>
			</div>
		) : (
			<>
				<h1>Sign in to True Recall</h1>
				<p class="subtitle">Connect your Obsidian plugin for AI-powered flashcards.</p>

				{error && <div class="error-message">{error}</div>}

				<form method="POST" class="auth-form">
					<input type="hidden" name="action" value="magic-link" />
					<div class="form-group">
						<label for="email">Email</label>
						<input
							type="email"
							id="email"
							name="email"
							placeholder="you@example.com"
							required
							autocomplete="email"
						/>
					</div>
					<button type="submit" class="btn btn-full">Send Magic Link</button>
				</form>
			</>
		)}
	</div>
</BaseLayout>

<script define:vars={{ redirectUrl }}>
	if (redirectUrl) {
		window.location.href = redirectUrl;
	}
</script>

<style>
	.plugin-auth-container {
		max-width: 400px;
		margin: 4rem auto;
	}

	.plugin-auth-container h1 {
		font-size: 1.75rem;
		margin-bottom: 0.5rem;
	}

	.subtitle {
		color: var(--sl-color-gray-3);
		margin-bottom: 2rem;
	}

	.auth-form {
		margin-bottom: 1rem;
	}

	.form-group {
		margin-bottom: 1.25rem;
	}

	.form-group label {
		display: block;
		margin-bottom: 0.5rem;
		color: var(--sl-color-gray-3);
		font-size: 0.875rem;
	}

	.form-group input {
		width: 100%;
		padding: 0.75rem 1rem;
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-sm);
		color: var(--sl-color-white);
		font-size: 1rem;
		box-sizing: border-box;
	}

	.form-group input:focus {
		outline: none;
		border-color: var(--sl-color-accent);
	}

	.form-group input::placeholder {
		color: var(--sl-color-gray-4);
	}

	.btn {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		background: var(--sl-color-accent);
		color: var(--sl-color-white);
		border: none;
		border-radius: var(--tr-radius-sm);
		font-size: 1rem;
		font-weight: 500;
		cursor: pointer;
		transition: filter 0.2s;
		text-decoration: none;
		text-align: center;
	}

	.btn:hover {
		filter: brightness(1.1);
		text-decoration: none;
	}

	.btn-full {
		width: 100%;
		display: block;
	}

	.error-message {
		background: color-mix(in srgb, var(--tr-color-error) 10%, transparent);
		border: 1px solid var(--tr-color-error);
		color: var(--tr-color-error);
		padding: 0.75rem 1rem;
		border-radius: var(--tr-radius-sm);
		margin-bottom: 1rem;
		font-size: 0.875rem;
	}

	.success-card,
	.authorize-card {
		text-align: center;
		padding: 2rem;
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-md);
	}

	.success-icon {
		font-size: 2.5rem;
		margin-bottom: 0.75rem;
	}

	.success-card h2,
	.authorize-card h2 {
		font-size: 1.25rem;
		margin-bottom: 0.5rem;
	}

	.success-card p,
	.authorize-card p {
		color: var(--sl-color-gray-3);
		margin-bottom: 0.5rem;
		line-height: 1.6;
	}

	.user-info {
		margin: 1.25rem 0;
		padding: 0.75rem 1rem;
		background: var(--sl-color-gray-7, var(--sl-color-black));
		border: 1px solid var(--sl-color-gray-5);
		border-radius: var(--tr-radius-sm);
	}

	.user-email {
		font-size: 0.9375rem;
		color: var(--sl-color-white);
	}

	.authorize-card form {
		margin-top: 1rem;
	}

	.hint {
		font-size: 0.875rem;
		color: var(--sl-color-gray-4);
		margin-top: 1rem;
	}

	.hint a {
		color: var(--sl-color-accent-high);
	}
</style>
